{
  /*
    Production/application.json (template)
    - Copy/edit this into config/application.json on the server.
    - Do NOT place secrets (passwords, keys) here; put them in config/secrets.json or provide via environment vars.
    - This template intentionally omits sensitive values so the loader will require them from secrets.json or env.
    - The data directory (database, keystore) is always a sibling of the config directory.
  */

  "storage": {
    "dataDir": "data",
    "databaseFilename": "chatbot.db",
    "keystoreFilename": "keystore.jks",
    "logsDir": "logs"
  },

  "network": {
    "host": "0.0.0.0", /* listen on all interfaces; for use in a Docker container */
    "port": 8080,
    "path": "",
    "connectorType": "HTTP"  /* set to HTTP if using a reverse proxy that handles TLS */
  },

  "cors": {
    /* Origins must be full origins (scheme + host + optional port) */
    "allowedOrigins": [
      "https://chatbot-client.yourdomain.com"
    ]
  },

  "ssl": {
    "port": 8443,
    /* keystorePassword / keyPassword must be provided in secrets.json or environment variables */
    "generateSelfSigned": true,
    "sanDomains": ["localhost"],
    "sanIpAddresses": ["127.0.0.1", "0.0.0.0", "10.0.2.2"]
    /* set generateSelfSigned false if you will provide real certs */
  },

  "database": {
    "vendor": "sqlite",
    "type": "file"
  },

  "encryption": {
    "keyVersion": 1,
    "masterKeys": {
      /* DO NOT store real keys here in the template; setup will generate values in secrets.json */
    }
  },

  "jwt": {
    "issuer": "chatbot-server",
    "userAudience": "chatbot-users",
    "workerAudience": "chatbot-workers",
    "realm": "chatbot-realm",
    "tokenExpirationMs": 86400000,
    "refreshExpirationMs": 604800000
    /* jwt.secret must be set in secrets.json or via environment variable */
  },

  "reverseProxy": {
    /*
      Enable this if the server is behind a reverse proxy (e.g., Caddy, Nginx, Cloudflare).
      - proxyCount: Number of trusted proxies in front of the server.
        Use 1 if directly behind Caddy.
        Use 2 if behind Cloudflare AND Caddy (or similar multi-proxy setup).
      - useXForwardedHeaders: Enable for Caddy, Nginx, etc. (most common)
      - useForwardedHeaders: Enable for RFC 7239 Forwarded header (less common, more secure)
      When disabled (false), X-Forwarded-For headers are ignored for security.
    */
    "enabled": true,
    "proxyCount": 1,
    "useXForwardedHeaders": true,
    "useForwardedHeaders": false
  }
}