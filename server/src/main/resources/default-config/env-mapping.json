{
  /*
    Environment Variable Mapping
    The values below are the NAMES of the environment variables
    that will be looked up in the system environment.
  */

  "serverUrl": "SERVER_URL",

  "setup": {
    "required": "CHATBOT_SETUP_REQUIRED"
  },

  "storage": {
    "dataDir": "SERVER_DATA_DIR",
    "databaseFilename": "SERVER_DATABASE_FILENAME",
    "keystoreFilename": "SERVER_KEYSTORE_FILENAME",
    "logsDir": "SERVER_LOGS_DIR"
  },

  "network": {
    "host": "SERVER_HOST",
    "port": "SERVER_PORT",
    "path": "SERVER_PATH",
    "connectorType": "SERVER_CONNECTOR_TYPE"
  },

  "cors": {
    "allowedOrigins": [
      "SERVER_CORS_ALLOWED_ORIGIN_1",
      "SERVER_CORS_ALLOWED_ORIGIN_2",
      "SERVER_CORS_ALLOWED_ORIGIN_3",
      "SERVER_CORS_ALLOWED_ORIGIN_4"
    ]
  },

  "ssl": {
    "port": "SSL_PORT",
    "keystorePassword": "SSL_KEYSTORE_PASSWORD",
    "keyAlias": "SSL_KEY_ALIAS",
    "keyPassword": "SSL_KEY_PASSWORD",
    "generateSelfSigned": "SSL_GENERATE_SELF_SIGNED",
    "sanDomains": [
      "SSL_SAN_DOMAIN_1",
      "SSL_SAN_DOMAIN_2"
    ],
    "sanIpAddresses": [
      "SSL_SAN_IP_ADDRESS_1",
      "SSL_SAN_IP_ADDRESS_2",
      "SSL_SAN_IP_ADDRESS_3"
    ]
  },

  "database": {
    "vendor": "DATABASE_VENDOR",
    "type": "DATABASE_TYPE",
    "filename": "DATABASE_FILENAME",
    "user": "DATABASE_USER",
    "password": "DATABASE_PASSWORD"
  },

  "encryption": {
    "keyVersion": "ENCRYPTION_KEY_VERSION",
    "masterKeys": {
      "1": "ENCRYPTION_MASTER_KEY_V1",
      "2": "ENCRYPTION_MASTER_KEY_V2"
    },
    "algorithm": "ENCRYPTION_ALGORITHM",
    "transformation": "ENCRYPTION_TRANSFORMATION",
    "keySizeBits": "ENCRYPTION_KEY_SIZE_BITS"
  },

  "jwt": {
    "issuer": "JWT_ISSUER",
    "userAudience": "JWT_USER_AUDIENCE",
    "workerAudience": "JWT_WORKER_AUDIENCE",
    "realm": "JWT_REALM",
    "secret": "JWT_SECRET",
    "tokenExpirationMs": "JWT_TOKEN_EXPIRATION_MS",
    "refreshExpirationMs": "JWT_REFRESH_EXPIRATION_MS"
  },

  "email": {
    "provider": "EMAIL_PROVIDER",
    "fromAddress": "EMAIL_FROM_ADDRESS",
    "properties": {
      "host": "EMAIL_HOST",
      "port": "EMAIL_PORT",
      "user": "EMAIL_USER",
      "password": "EMAIL_PASSWORD",
      "auth": "EMAIL_AUTH",
      "starttls": "EMAIL_STARTTLS",
      "debug": "EMAIL_DEBUG",
      "mail.smtp.ssl.trust": "EMAIL_SMTP_SSL_TRUST"
    }
  },

  "accountSecurityMode": "CHATBOT_ACCOUNT_SECURITY_MODE",

  "reverseProxy": {
    "enabled": "REVERSE_PROXY_ENABLED",
    "proxyCount": "REVERSE_PROXY_COUNT",
    "useXForwardedHeaders": "REVERSE_PROXY_USE_X_FORWARDED",
    "useForwardedHeaders": "REVERSE_PROXY_USE_RFC_FORWARDED"
  },

  "authPolicy": {
    "passwordConfig": {
      "minLength": "AUTH_PASSWORD_MIN_LENGTH",
      "maxLength": "AUTH_PASSWORD_MAX_LENGTH",
      "requireLowercase": "AUTH_PASSWORD_REQUIRE_LOWERCASE",
      "requireUppercase": "AUTH_PASSWORD_REQUIRE_UPPERCASE",
      "requireDigit": "AUTH_PASSWORD_REQUIRE_DIGIT",
      "requireSpecialChar": "AUTH_PASSWORD_REQUIRE_SPECIAL_CHAR",
      "checkCommonPasswords": "AUTH_PASSWORD_CHECK_COMMON"
    },
    "usernameConfig": {
      "minLength": "AUTH_USERNAME_MIN_LENGTH",
      "maxLength": "AUTH_USERNAME_MAX_LENGTH",
      "allowedRegexPattern": "AUTH_USERNAME_ALLOWED_REGEX"
    },
    "maxFailedAttempts": "AUTH_MAX_FAILED_ATTEMPTS",
    "lockoutWindowMinutes": "AUTH_LOCKOUT_WINDOW_MINUTES"
  }
}
