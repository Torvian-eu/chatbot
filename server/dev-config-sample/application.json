{
  /*
    Development application.json
    Used when running from the IDE or for local development.
    This file intentionally contains development-friendly defaults.
    Copy this file to a directory outside the project root and point
    CHATBOT_SERVER_CONFIG_DIR to that directory.
  */

  "storage": {
    "dataDir": "data",
    "databaseFilename": "chatbot_dev.db",
    "keystoreFilename": "keystore.jks",
    "logsDir": "logs"
  },

  "network": {
    "host": "localhost",
    "port": 8080,                   // HTTP port (if HTTP connector used)
    "path": "",
    "connectorType": "HTTPS"        // Use HTTPS for dev to mimic production
  },

  "ssl": {
    "port": 8443,                 // HTTPS port
    /* keystorePassword / keyAlias / keyPassword are generated by setup and stored in secrets.json */
    "generateSelfSigned": true,
    "sanDomains": ["localhost"],
    "sanIpAddresses": ["127.0.0.1", "0.0.0.0", "10.0.2.2"]
  },

  "database": {
    "vendor": "sqlite",
    "type": "file"
  },

  "encryption": {
    "keyVersion": 1,
    "masterKeys": {
      /* For development the master key is provided in secrets.json */
    }
  },

  "jwt": {
    "issuer": "chatbot-server-dev",
    "audience": "chatbot-users",
    "realm": "chatbot-realm",
    "tokenExpirationMs": 86400000,
    "refreshExpirationMs": 604800000
    /* jwt.secret is provided in secrets.json for dev */
  }
}
