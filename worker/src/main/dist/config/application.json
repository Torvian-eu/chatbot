{
  /*
    Worker application.json (template)
    - Copy/edit this into config/application.json.
    - Keep non-secret runtime defaults here.
    - Secrets stay in secrets.json, generated by --setup.
  */

  "worker": {
    "server": {
      "baseUrl": "http://localhost:8080/"
    },
    "identity": {
      "uid": "",
      "certificateFingerprint": "",
      "certificatePem": ""
    },
    "storage": {
      "secretsJsonPath": "./secrets.json",
      "tokenFilePath": "./token.json"
    },
    "auth": {
      "refreshSkewSeconds": 60
    }
  }
}

